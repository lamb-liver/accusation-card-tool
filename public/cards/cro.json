[{"id":"cro01","hasAlternateArt":true,"alternateSource":"預購特典","name":"第十三夜","faction":"鴉教團","type":"教主","source":"夜與序幕","effect":"當你觸發詠頌時，抽1張牌。你的每個回合限一次，棄置你2張手牌，將你棄牌區另外1張牌拿回手。","symbols":["夜幕","知識"]},{"id":"cro02","name":"黑色葬禮","faction":"鴉教團","type":"儀式","source":"夜與序幕","calamity":3,"effect":"執行儀式。若你擁有(4*凋零)，且你棄牌區有至少4個信徒。","symbols":["凋零"]},{"id":"cro03","name":"群鴉風暴","faction":"鴉教團","type":"儀式","source":"夜與序幕","calamity":1,"effect":"執行儀式。若你場上有至少3個地點。","symbols":["夜幕"]},{"id":"cro04","name":"無聲奉獻","faction":"鴉教團","type":"儀式","source":"夜與序幕","calamity":2,"effect":"執行儀式。若你場上有至少4個夜幕信徒。","symbols":["知識"]},{"id":"cro05","hasAlternateArt":true,"alternateSource":"閃卡包","name":"鴉仕女","faction":"鴉教團","type":"信徒","source":"夜與序幕","volume":4,"calamity":3,"effect":"詠頌：抽1張牌。","symbols":["夜幕"]},{"id":"cro06","name":"鴉司祭","faction":"鴉教團","type":"信徒","source":"夜與序幕","volume":3,"calamity":3,"effect":"詠頌：將你手牌至多1個信徒放置到你場上，然後觸發該信徒的詠頌效果。","symbols":["夜幕","知識"]},{"id":"cro07","name":"信使","faction":"鴉教團","type":"信徒","source":"夜與序幕","volume":3,"calamity":3,"effect":"詠頌：抽1張牌，然後雙方玩家棄置1張手牌。","symbols":["夜幕"]},{"id":"cro08","name":"烏血醫生","faction":"鴉教團","type":"信徒","source":"夜與序幕","volume":3,"calamity":3,"effect":"詠頌：將場上1個信徒變為罪惡。","symbols":["禁忌"]},{"id":"cro09","hasAlternateArt":true,"alternateSource":"閃卡包","name":"失眠掘墓人","faction":"鴉教團","type":"信徒","source":"夜與序幕","volume":3,"calamity":3,"effect":"詠頌：將你棄牌區1個聲量3以下的信徒拿回手，若你場上有「墓園」，觸發該信徒的詠頌效果。","symbols":["凋零"]},{"id":"cro10","name":"迷路的亡魂","faction":"鴉教團","type":"信徒","source":"夜與序幕","volume":2,"calamity":2,"effect":"詠頌：破壞敵方場上1個儀式。","symbols":["夜幕"]},{"id":"cro11","name":"割舌的僧侶","faction":"鴉教團","type":"信徒","source":"夜與序幕","volume":3,"calamity":0,"effect":"這個信徒無法控訴。你每擁有(3*夜幕)，你的魔法災厄增加1。","symbols":["禁忌"]},{"id":"cro12","hasAlternateArt":true,"alternateSource":"賽季積分","name":"鐘塔守衛","faction":"鴉教團","type":"信徒","source":"夜與序幕","volume":3,"calamity":0,"effect":"當這個信徒控訴時，將你棄牌區1個地點拿回手。","symbols":["禁忌"]},{"id":"cro13","name":"灰眼童","faction":"鴉教團","type":"信徒","source":"夜與序幕","volume":5,"calamity":0,"effect":"當這個信徒控訴時，破壞你場上1個信徒。","symbols":["夜幕","凋零"]},{"id":"cro14","hasAlternateArt":true,"alternateSource":"閃卡包","name":"鴉雛","faction":"鴉教團","type":"信徒","source":"夜與序幕","volume":2,"calamity":3,"effect":"詠頌：棄置你2張手牌，將你棄牌區另外1張牌拿回手。這個信徒不會變為罪惡。","symbols":["知識"]},{"id":"cro15","name":"黑夫人","faction":"鴉教團","type":"信徒","source":"夜與序幕","volume":3,"calamity":3,"effect":"詠頌：你每擁有(3*凋零)，目標敵方棄置1張手牌。","symbols":["凋零"]},{"id":"cro16","name":"夜渡橋","faction":"鴉教團","type":"地點","source":"夜與序幕","guard":4,"calamity":2,"locationType":"橋","effect":"地點行動：你每擁有(2*禁忌)，破壞場上1個信徒。","symbols":["夜幕"]},{"id":"cro17","name":"鐘塔","faction":"鴉教團","type":"地點","source":"夜與序幕","guard":5,"calamity":0,"locationType":"聖地","effect":"雙方信徒控訴後被破壞。","symbols":["禁忌"]},{"id":"cro18","name":"巢修道院","faction":"鴉教團","type":"地點","source":"夜與序幕","guard":5,"calamity":0,"locationType":"聖地","effect":"若你擁有(4*知識)，你每回合第一個觸發的詠頌效果結算完後，額外再觸發1次。","symbols":["知識"]},{"id":"cro19","name":"羽墓園","faction":"鴉教團","type":"地點","source":"夜與序幕","guard":6,"calamity":4,"locationType":"墓園","effect":"地點行動：你每擁有(1*凋零)，將你棄牌區的1個信徒拿回手，然後破壞這個地點。","symbols":["凋零"]},{"id":"cro20","name":"湖畔墓園","faction":"鴉教團","type":"地點","source":"夜與序幕","guard":4,"calamity":4,"locationType":"墓園","effect":"地點行動：你棄牌區每有2個信徒，將你棄牌區1張魔法拿回手，然後破壞這個地點。","symbols":["凋零"]},{"id":"cro21","name":"黯燭","faction":"鴉教團","type":"魔法","source":"夜與序幕","stardust":3,"calamity":1,"effect":"破壞場上1張非教主牌。星塵效果：這個魔法災厄增加2。","symbols":[]},{"id":"cro22","name":"烏骨療法","faction":"鴉教團","type":"魔法","source":"夜與序幕","stardust":2,"calamity":3,"effect":"解除場上1個信徒的罪惡。星塵效果：可將場上1個信徒變為罪惡。","symbols":[]},{"id":"cro23","name":"失聲詛咒","faction":"鴉教團","type":"魔法","source":"夜與序幕","stardust":4,"calamity":3,"effect":"本回合敵方無法控訴你的詠頌。星塵效果：改為本回合敵方無法控訴。","symbols":[]},{"id":"cro24","name":"鳴災","faction":"鴉教團","type":"魔法","source":"夜與序幕","stardust":3,"calamity":3,"effect":"破壞場上至多2個罪惡信徒。星塵效果：可改為除外場上至多2個罪惡信徒。","symbols":[]}]