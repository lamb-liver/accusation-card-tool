[{"id":"fox01","hasAlternateArt":true,"alternateSource":"預購特典","name":"雪白尾","faction":"白狐神社","type":"教主","source":"夜與序幕","effect":"你的執行儀式災厄增加1。你的每個回合限一次，從你棄牌區或牌庫尋找至多1個「荒野」放置到你場上。","symbols":["野性","知識"]},{"id":"fox02","name":"狐嫁夜","faction":"白狐神社","type":"儀式","source":"夜與序幕","calamity":3,"effect":"執行儀式。若你擁有(5*野性)，並且你場上有「雪白尾」或「祈願之子」。","symbols":["夜幕"]},{"id":"fox03","name":"稻魂祭","faction":"白狐神社","type":"儀式","source":"夜與序幕","calamity":2,"effect":"執行儀式。若你擁有(5*自然)。","symbols":["自然"]},{"id":"fox04","name":"返靈舞","faction":"白狐神社","type":"儀式","source":"夜與序幕","calamity":2,"effect":"執行儀式：若你場上的地點守護總和至少為18。","symbols":["知識"]},{"id":"fox05","hasAlternateArt":true,"alternateSource":"閃卡包","name":"神巫","faction":"白狐神社","type":"信徒","source":"夜與序幕","volume":1,"calamity":4,"effect":"詠頌：你每擁有(2*夜幕)，將你棄牌區1個地點拿回手。","symbols":["野性","知識"]},{"id":"fox06","name":"神隱修士","faction":"白狐神社","type":"信徒","source":"夜與序幕","volume":3,"calamity":3,"effect":"詠頌：若你場上有至少2個「聖地」，完成你場上1個儀式，然後破壞你場上1個「聖地」。","symbols":["知識"]},{"id":"fox07","hasAlternateArt":true,"alternateSource":"賽季積分","name":"焚香師","faction":"白狐神社","type":"信徒","source":"夜與序幕","volume":2,"calamity":4,"effect":"詠頌：破壞你場上1個「荒野」，然後破壞對方場上至多2個聲量總和為該「荒野」守護以下的信徒。","symbols":["自然"]},{"id":"fox08","name":"稻草人","faction":"白狐神社","type":"信徒","source":"夜與序幕","volume":2,"effect":"駐守3。你場上的「荒野」不會被襲擊。","symbols":["自然"]},{"id":"fox09","hasAlternateArt":true,"alternateSource":"閃卡包","name":"白衣武士","faction":"白狐神社","type":"信徒","source":"夜與序幕","volume":2,"effect":"駐守2。你每擁有(1*夜幕)，這個信徒襲擊聲量增加1。","symbols":["夜幕"]},{"id":"fox10","hasAlternateArt":true,"alternateSource":"積分排名獎勵","name":"祈願之子","faction":"白狐神社","type":"信徒","source":"夜與序幕","volume":3,"effect":"駐守2。若你擁有(3*自然)，你場上的儀式不會被破壞與除外。","symbols":["野性"]},{"id":"fox11","hasAlternateArt":true,"alternateSource":"閃卡包","name":"燈籠巡遊","faction":"白狐神社","type":"信徒","source":"夜與序幕","volume":2,"calamity":3,"effect":"駐守2。目標敵方下一回合無法襲擊。","symbols":["夜幕"]},{"id":"fox12","name":"面守","faction":"白狐神社","type":"信徒","source":"夜與序幕","volume":2,"effect":"駐守2。你場上每有1個駐守中的信徒，這個信徒控訴聲量增加2。","symbols":["夜幕","野性"]},{"id":"fox13","name":"狐渡","faction":"白狐神社","type":"信徒","source":"夜與序幕","volume":3,"effect":"雙方場上每有1個「橋」，這個信徒控訴聲量增加2。","symbols":["野性"]},{"id":"fox14","name":"櫻華","faction":"白狐神社","type":"信徒","source":"夜與序幕","volume":1,"effect":"駐守1。這個信徒不會變為罪惡。","symbols":["夜幕","自然"]},{"id":"fox15","name":"神巫之間","faction":"白狐神社","type":"地點","source":"夜與序幕","guard":5,"calamity":3,"locationType":"圖書館","effect":"地點行動：你每擁有(2*知識)，將你場上一個信徒解除罪惡，然後啟動該信徒的駐守效果。","symbols":["知識"]},{"id":"fox16","name":"狐尾橋","faction":"白狐神社","type":"地點","source":"夜與序幕","guard":4,"calamity":0,"locationType":"橋","effect":"你每擁有(3*野性)，你的執行儀式災厄增加1。","symbols":["野性"]},{"id":"fox17","name":"神隱之森","faction":"白狐神社","type":"地點","source":"夜與序幕","guard":3,"calamity":0,"locationType":"荒野","effect":"(沒有任何效果)","symbols":["自然","野性"]},{"id":"fox18","name":"稻原","faction":"白狐神社","type":"地點","source":"夜與序幕","guard":2,"calamity":0,"locationType":"荒野","effect":"(沒有任何效果)","symbols":["自然","自然","夜幕"]},{"id":"fox19","name":"本殿","faction":"白狐神社","type":"地點","source":"夜與序幕","guard":5,"calamity":3,"locationType":"聖地","effect":"從你的棄牌區或牌庫尋找至多1個儀式放置到你的場上。","symbols":["野性"]},{"id":"fox20","name":"遺忘神龕","faction":"白狐神社","type":"地點","source":"夜與序幕","guard":5,"calamity":3,"locationType":"聖地","effect":"若這個地點守護至少為10，完成你場上一個儀式，然後破壞這個地點。","symbols":["夜幕"]},{"id":"fox21","name":"狐火","faction":"白狐神社","type":"魔法","source":"夜與序幕","stardust":3,"calamity":3,"effect":"破壞場上1個聲量3以下的信徒。星塵效果：可額外破壞場上1個聲量2以下的信徒。","symbols":[]},{"id":"fox22","name":"魂燈","faction":"白狐神社","type":"魔法","source":"夜與序幕","stardust":3,"calamity":4,"effect":"目標敵方可棄置手牌1個信徒，否則隨機棄置一張手牌。星塵效果：將你棄牌區1個信徒拿回手。","symbols":[]},{"id":"fox23","name":"時雨","faction":"白狐神社","type":"魔法","source":"夜與序幕","stardust":3,"calamity":4,"effect":"你場上每有2個地點，抽1張牌。星塵效果：破壞你場上所有荒野，然後破壞敵方場上等量信徒。","symbols":[]},{"id":"fox24","name":"結靈","faction":"白狐神社","type":"魔法","source":"夜與序幕","stardust":2,"calamity":3,"effect":"你場上每有1個駐守中的信徒，本回合下一次襲擊聲量增加2。星塵效果：以聲量2進行一次襲擊。","symbols":[]}]