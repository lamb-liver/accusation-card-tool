[{"id":"exi01","name":"斷翅的鴉","faction":"放逐者","type":"信徒","source":"比賽積分兌換","volume":2,"calamity":3,"stardust":1,"effect":"詠頌：抽1張牌，然後棄置你1張手牌。","symbols":["夜幕"]},{"id":"exi02","name":"酒鬼傑克","faction":"放逐者","type":"信徒","source":"比賽積分兌換","volume":3,"effect":"當這個信徒控訴時，破壞你場上1個信徒。","symbols":["凋零"]},{"id":"exi03","name":"黑尾","faction":"放逐者","type":"信徒","source":"比賽積分兌換","volume":2,"effect":"雙方執行儀式災厄減少1。","symbols":["野性"]},{"id":"exi04","name":"沼澤女巫","faction":"放逐者","type":"信徒","source":"比賽積分兌換","volume":1,"effect":"駐守3。這個信徒無法駐守「荒野」。","symbols":["自然"]},{"id":"exi05","name":"竊密者","faction":"放逐者","type":"信徒","source":"比賽積分兌換","volume":2,"calamity":3,"stardust":1,"effect":"詠頌：獻祭你手牌或棄牌區至多1張儀式。","symbols":["知識"]},{"id":"exi06","name":"說謊的病患","faction":"放逐者","type":"信徒","source":"比賽積分兌換","volume":5,"effect":"當這個信徒控訴時，或是這個信徒變為罪惡時，除外這個信徒。","symbols":["煉金"]},{"id":"exi07","name":"空白","faction":"放逐者","type":"信徒","source":"比賽積分兌換","volume":0,"effect":"當你打出原始災厄2以下的魔法時，解除你場上1個信徒的罪惡，然後將這個信徒拿回手。","symbols":["醫藥"]},{"id":"exi08","name":"邪祟獵人","faction":"放逐者","type":"信徒","source":"比賽積分兌換","volume":1,"calamity":3,"effect":"詠頌：除外場上1個聲量3以上的罪惡信徒。","symbols":["禁忌"]},{"id":"exi09","name":"盜火賊","faction":"放逐者","type":"信徒","source":"比賽積分兌換","volume":2,"calamity":3,"effect":"詠頌：除外你棄牌區至多2張魔法，然後除外目標敵方棄牌區等量卡牌。","symbols":["灰燼"]},{"id":"exi10","name":"追書者地窖","faction":"放逐者","type":"地點","source":"比賽積分兌換","guard":5,"calamity":0,"locationType":"圖書館","effect":"你棄牌區每有1張儀式，你的魔法災厄增加1。","symbols":["夜幕"]},{"id":"exi11","name":"惱人廣播器","faction":"放逐者","type":"地點","source":"比賽積分兌換","guard":5,"calamity":0,"locationType":"聖地","effect":"若信徒將發動控訴時效果，無效該效果，然後將這個地點置入陰謀區。","symbols":["凋零"]},{"id":"exi12","name":"Δ議會紀念碑","faction":"放逐者","type":"地點","source":"比賽積分兌換","guard":4,"calamity":0,"locationType":"庭院","effect":"若你場上有至少2個「庭院」，且你已完成1個儀式，你的儀式災厄增加1。","symbols":["知識"]}]